{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "build",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/ym/v2/**",
        "function": "ymApi"
      },
      {
        "source": "/api/km-analytics",
        "function": "kmAnalytics"
      },
      {
        "source": "/mm/chart",
        "function": "mmChart"
      },
      {
        "source": "!/**/*.html",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions",
    "codebase": "default"
  }
}
